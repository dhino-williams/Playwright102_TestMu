{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": [
    "tests/**/*",           // Matches any files/extensions inside the tests folder
    "playwright.config.*"   // Safely catches .ts, .mts, or .js variations
  ],
  "exclude": ["dist", "node_modules"]
}